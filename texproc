def main():
    parser = argparse.ArgumentParser(description="Texture crop + scale — kitty image preview")
    parser.add_argument("input", nargs="?", help="Input image")
    parser.add_argument("-o", "--output", help="Output path")
    parser.add_argument("-c", "--crop", type=float, default=0.8, help="Crop %% (0.1-1.0)")
    parser.add_argument("-s", "--size", type=int, default=512, help="Output px size")
    parser.add_argument("--tui", action="store_true", help="TUI mode")
    args = parser.parse_args()

    if not args.input:
        console.rule("[bold cyan]texproc[/bold cyan]")
        args.input = Prompt.ask("[yellow]Input image path[/yellow]")
        args.tui = True

    if not os.path.exists(args.input):
        console.print(f"[red]File not found: {args.input}[/red]")
        sys.exit(1)

    # Handle zip
    if Path(args.input).suffix.lower() == ".zip":
        args.input = extract_zip(args.input)
        if not args.output:
            p = Path(args.input)
            args.output = str(p.parent / f"{p.stem}_out{p.suffix}")

    if not args.output:
        p = Path(args.input)
        args.output = str(p.parent / f"{p.stem}_out{p.suffix}")

    if args.tui:
        tui_mode(args.input, args.output)
    else:
        process_imagemagick(args.input, args.output, args.crop, args.size)
        print(f"Done: {args.output}")


if __name__ == "__main__":
    main()
